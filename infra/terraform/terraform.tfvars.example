###############################################################################
# APDL Terraform Variables -- Example
#
# Copy this file and customize for your deployment:
#   cp terraform.tfvars.example terraform.tfvars
#
# Or use the environment-specific files:
#   terraform plan -var-file=environments/dev.tfvars
#   terraform plan -var-file=environments/staging.tfvars
#   terraform plan -var-file=environments/prod.tfvars
###############################################################################

# -- General ------------------------------------------------------------------
environment = "dev"              # One of: dev, staging, prod
aws_region  = "us-east-1"       # AWS region for all resources
# project_name = "apdl"         # Project name used in resource naming

# -- Networking ---------------------------------------------------------------
# vpc_cidr = "10.0.0.0/16"      # VPC CIDR block

# -- EKS ---------------------------------------------------------------------
# eks_cluster_version     = "1.29"
# eks_node_instance_types = ["t3.large"]
# eks_min_nodes           = 2
# eks_max_nodes           = 6
# eks_desired_nodes       = 3

# -- Redis (ElastiCache) -----------------------------------------------------
# redis_node_type       = "cache.t3.medium"
# redis_num_cache_nodes = 2      # Includes primary; set > 1 for auto-failover

# -- ClickHouse ---------------------------------------------------------------
# clickhouse_instance_type = "r6i.xlarge"
# clickhouse_volume_size   = 500 # GB
# clickhouse_node_count    = 1

# -- PostgreSQL (RDS) --------------------------------------------------------
# postgres_instance_class    = "db.t3.medium"
# postgres_allocated_storage = 100  # GB
# postgres_engine_version    = "16.2"
# postgres_database_name     = "apdl"

# -- Monitoring ---------------------------------------------------------------
# alert_email = "team@example.com"  # Leave empty to skip email subscription

# -- DNS (optional) -----------------------------------------------------------
# domain_name = "apdl.example.com"
